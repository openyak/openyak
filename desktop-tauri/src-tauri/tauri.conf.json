{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "OpenYak",
  "identifier": "com.openyak.desktop",
  "version": "1.0.4",
  "build": {
    "frontendDist": "../../frontend/out",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm --prefix .. run build:frontend && npm --prefix .. run build:backend",
    "beforeDevCommand": ""
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OpenYak",
        "width": 1000,
        "height": 700,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://ipc.localhost http://127.0.0.1:* https://*; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; script-src 'self' 'unsafe-inline'; worker-src 'self' blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "deb",
      "appimage",
      "rpm"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": {
      "../../backend/dist/openyak-backend": "backend",
      "../../backend/resources/nodejs": "nodejs"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": "Developer ID Application: wangzhang wu (46KF5Z549N)",
      "dmg": {
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        },
        "windowSize": {
          "width": 660,
          "height": 400
        }
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "openyak"
        ]
      }
    },
    "updater": {
      "endpoints": [
        "https://open-yak.com/update/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI2NzhEQTg4RUE2NjhDRjQKUldUMGpHYnFpTnA0dGtwdE5YK3dJT0N2Z0tUcHNXNStIcVU2bEpmZ3lpRUo1UEZYTWNaVWhDUEkK"
    },
    "shell": {
      "open": true
    }
  }
}
